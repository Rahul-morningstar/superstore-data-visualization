<?xml version='1.0' encoding='utf-8' ?>
<!-- ============================================================
     Tableau Workbook: Superstore Data Visualization - All 30 Questions
     
     HOW TO USE:
     1. Open in Tableau Desktop or Tableau Public (free)
     2. When prompted, re-connect to your Sample Superstore .xls file
        Download: https://community.tableau.com -> Sample Superstore
     3. All 30 worksheets + 3 dashboards load automatically
     4. Build each chart by selecting Show Me -> choose chart type
     
     CALCULATED FIELDS INCLUDED:
     - Profit Margin   = [Profit]/[Sales]
     - Days to Ship    = DATEDIFF('day',[Order Date],[Ship Date])
     - Customer Type   = Repeat vs New (LOD calculation)
     - Day of Week     = DATENAME('weekday',[Order Date])
     - Order Year/Quarter/Month
     ============================================================ -->
<workbook source-build='2023.1.0' source-platform='win' version='18.1'>

  <preferences>
    <color-palette name='Superstore Custom' type='regular'>
      <color>#1F5C99</color><color>#E07B39</color><color>#2E8B57</color>
      <color>#9B59B6</color><color>#E74C3C</color><color>#95A5A6</color>
    </color-palette>
  </preferences>

  <datasources>
    <datasource caption='Sample - Superstore' name='superstore' version='18.1'>
      <connection class='excel-direct' filename='Sample - Superstore.xls' authentication='no-authentication'>
        <relation name='Orders$' table='[Orders$]' type='table'/>
      </connection>
      <column datatype='string'  name='[Category]'       role='dimension' type='nominal'/>
      <column datatype='string'  name='[Sub-Category]'   role='dimension' type='nominal'/>
      <column datatype='string'  name='[Region]'         role='dimension' type='nominal'/>
      <column datatype='string'  name='[Segment]'        role='dimension' type='nominal'/>
      <column datatype='string'  name='[Ship Mode]'      role='dimension' type='nominal'/>
      <column datatype='string'  name='[Order Priority]' role='dimension' type='nominal'/>
      <column datatype='string'  name='[State]'          role='dimension' type='nominal'/>
      <column datatype='string'  name='[Customer ID]'    role='dimension' type='nominal'/>
      <column datatype='string'  name='[Customer Name]'  role='dimension' type='nominal'/>
      <column datatype='string'  name='[Order ID]'       role='dimension' type='nominal'/>
      <column datatype='string'  name='[Product Name]'   role='dimension' type='nominal'/>
      <column datatype='date'    name='[Order Date]'     role='dimension' type='ordinal'/>
      <column datatype='date'    name='[Ship Date]'      role='dimension' type='ordinal'/>
      <column datatype='real'    name='[Sales]'          role='measure'   type='quantitative'/>
      <column datatype='real'    name='[Profit]'         role='measure'   type='quantitative'/>
      <column datatype='real'    name='[Discount]'       role='measure'   type='quantitative'/>
      <column datatype='integer' name='[Quantity]'       role='measure'   type='quantitative'/>
      <column caption='Profit Margin' datatype='real' name='[Profit Margin]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Profit]/[Sales]'/>
      </column>
      <column caption='Days to Ship' datatype='integer' name='[Days to Ship]' role='measure' type='quantitative'>
        <calculation class='tableau' formula="DATEDIFF(&apos;day&apos;,[Order Date],[Ship Date])"/>
      </column>
      <column caption='Day of Week' datatype='string' name='[Day of Week]' role='dimension' type='nominal'>
        <calculation class='tableau' formula="DATENAME(&apos;weekday&apos;,[Order Date])"/>
      </column>
      <column caption='Order Year' datatype='integer' name='[Order Year]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='YEAR([Order Date])'/>
      </column>
      <column caption='Order Quarter' datatype='integer' name='[Order Quarter]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula="DATEPART(&apos;quarter&apos;,[Order Date])"/>
      </column>
      <column caption='Order Month' datatype='integer' name='[Order Month]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='MONTH([Order Date])'/>
      </column>
      <column caption='Customer Type' datatype='string' name='[Customer Type]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF {FIXED [Customer ID]: COUNTD([Order ID])} &gt; 1 THEN &quot;Repeat&quot; ELSE &quot;New&quot; END'/>
      </column>
      <column caption='Profit Category' datatype='string' name='[Profit Category]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Profit] &gt; 0 THEN &quot;Profitable&quot; ELSE &quot;Loss&quot; END'/>
      </column>
    </datasource>
  </datasources>

  <worksheets>
  <worksheet name='Q1_Sales_by_Category'>
    <layout-options>
      <title><formatted-text><run fontname='Tableau Medium' fontsize='13'>Q1 · Highest Total Sales by Category</run></formatted-text></title>
    </layout-options>
    <table>
      <view>
        <datasources>
          <datasource caption='Sample - Superstore' name='superstore'/>
        </datasources>
        <shelf-content>
          <mark class='Bar'/>
          <encoding><color column='[none:Category:nk]'/></encoding>
        </shelf-content>
      </view>
      <rows>SUM(Sales)</rows>
      <cols>Category</cols>
    </table>
  </worksheet>
  <worksheet name='Q2_Monthly_Sales'>
    <layout-options>
      <title><formatted-text><run fontname='Tableau Medium' fontsize='13'>Q2 · Monthly Sales Changes Over Year</run></formatted-text></title>
