          <mark class='Line'/>
          <encoding><color column='[none:Category:nk]'/></encoding>
        </shelf-content>
      </view>
      <rows>SUM(Sales)</rows>
      <cols>MONTH(Order Date)</cols>
    </table>
  </worksheet>
